{
  "name": "agent-awareness-plugin-debug",
  "version": "0.1.0",
  "description": "Debug plugin for agent-awareness — send test messages through the channel pipeline",
  "type": "module",
  "bin": {
    "agent-awareness-debug": "./src/cli.js"
  },
  "exports": {
    ".": "./index.js"
  },
  "main": "./index.js",
  "files": [
    "index.js",
    "src/**/*.js",
    "src/**/*.d.ts",
    "src/cli.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit false",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent-awareness",
    "plugin",
    "debug",
    "channel",
    "testing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edimuj/agent-awareness-plugins.git",
    "directory": "debug"
  },
  "peerDependencies": {
    "agent-awareness": ">=0.4.0"
  }
}
